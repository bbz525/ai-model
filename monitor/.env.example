# ===================== 摄像头配置 =====================
CAMERA_URL=http://192.168.1.13:8081
# CAMERA_URL=0  # 本地USB摄像头
RECONNECT_INTERVAL=5
MAX_RECONNECT_ATTEMPTS=0

# ===================== Motion 移动侦测配置 =====================
MIN_AREA=500
THRESHOLD=25
FRAME_RESIZE=500

# ===================== Ollama 配置 =====================
OLLAMA_API=http://127.0.0.1:11434/api/generate
MODEL_NAME=qwen3.5
DETECT_AFTER_MOTION=2
OLLAMA_TIMEOUT=60
OLLAMA_MAX_RETRIES=2

# ===================== QQ 机器人配置 =====================
# 方案1：官方机器人（QQ Open Platform）
QQ_BOT_TYPE=official
QQ_OFFICIAL_APPID=your_qq_appid_here
QQ_OFFICIAL_SECRET=your_qq_secret_here
# user_openid 在用户首次给机器人发消息后从日志获取
QQ_OFFICIAL_USER_ID=your_qq_user_openid_here
QQ_HTTP_PORT=8083
QQ_ENABLE=true

# 方案2：NapCat/go-cqhttp（备选）
# QQ_BOT_TYPE=napcat
# QQ_BOT_API=http://127.0.0.1:3000
# QQ_GROUP_ID=123456789

# ===================== TTS 语音配置 =====================
TTS_API_KEY=your_tts_api_key_here
TTS_BASE_URL=https://www.dmxapi.cn/v1
TTS_ENABLE=true
TTS_MIN_LEVEL=info
TTS_REPEAT=1
TTS_QUEUE_SIZE=10

# ===================== OpenAI API（respApi.py 用）=====================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://aihubmix.com/v1
